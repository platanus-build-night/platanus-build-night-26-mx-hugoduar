# ─────────────────────────────────────────────────────────────────────────────
# Noctua Review UI — environment variables
#
# Copy to ui/.env.local. Restart `npm run dev` after editing — NEXT_PUBLIC_*
# vars are inlined into the client bundle at startup and don't hot-reload.
# ─────────────────────────────────────────────────────────────────────────────

# ── Client-facing (shipped to the browser) ───────────────────────────────────

# Origin the browser uses to talk to the Django API. On macOS keep 127.0.0.1
# instead of localhost — Node's dns prefers ::1 (IPv6) but `manage.py runserver`
# only binds IPv4, so localhost resolves but doesn't connect.
NEXT_PUBLIC_NOCTUA_API=http://127.0.0.1:8000

# Bearer token sent with every browser API call. Must match NOCTUA_API_TOKEN
# in the project root .env. Yes, it ends up in the client bundle — that's
# acceptable for a localhost dev tool; for any kind of shared deployment,
# proxy everything through Next.js Route Handlers like /api/missions/[id]/logs
# already does.
NEXT_PUBLIC_NOCTUA_TOKEN=

# ── Server-only (used by Next.js Route Handlers; never reaches the browser) ──

# SSE proxy origin and token. The /api/missions/[id]/logs route handler uses
# these to call the Django API server-side so the token isn't exposed in the
# query string or browser bundle.
NOCTUA_API=http://127.0.0.1:8000
NOCTUA_API_TOKEN=
