# ─────────────────────────────────────────────────────────────────────────────
# Noctua — environment variables
#
# Copy this file to .env and fill in the values. Anything left blank disables
# the matching feature; Noctua won't crash, but the producer or integration
# that needs it will fail with a clear error.
# ─────────────────────────────────────────────────────────────────────────────

# === Required: core control plane ────────────────────────────────────────────

# Bearer token the CLI, UI, and webhook callers must send. Generate any random
# value: `openssl rand -hex 32`.
NOCTUA_API_TOKEN=

# Anthropic API key. Used by the planner (Sonnet) and the PR producer's edit
# loop (Opus). Without this, every mission fails before it boots.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# GitHub personal access token. Used by the sandbox to push branches and by
# the gh CLI to open PRs against the demo repo. `repo` scope is enough.
# Easiest path: `gh auth login` then `gh auth token`.
GITHUB_TOKEN=

# === Required for PR producer: target repo ───────────────────────────────────

# The repo Noctua opens PRs against by default. Replace with your own fork.
NOCTUA_DEMO_REPO=https://github.com/<your-user>/noctua-demo-app

# === Required: postgres + redis (defaults match docker-compose.yml) ──────────

DATABASE_URL=postgres://noctua:noctua@localhost:5432/noctua
REDIS_URL=redis://localhost:6379/0

# === Optional: Composio (only needed for non-PR producers) ───────────────────
#
# The social_post, clinical_analysis, diagnostic, and cad producers route
# external tool calls through Composio's managed gateway. PR missions don't
# need this — leave blank if you only care about code-fix missions.
# Get a key at https://app.composio.dev/
COMPOSIO_API_KEY=
# COMPOSIO_USER_ID=noctua_default  # one Composio user_id per Noctua instance

# === Optional: WhatsApp via Kapso ────────────────────────────────────────────
#
# Lets you fire missions and receive completion replies over WhatsApp.
# Leave blank to disable.
KAPSO_API_KEY=
KAPSO_WEBHOOK_SECRET=
KAPSO_API_BASE_URL=https://api.kapso.ai
# WhatsApp phone number ID issued by Kapso for your business account.
KAPSO_PHONE_NUMBER_ID=
# Comma-separated list of E.164-formatted phone numbers allowed to message
# Noctua (without the leading +). Anyone outside this list gets ignored.
# Example: NOCTUA_WHATSAPP_ALLOWLIST=15551234567,15557654321
NOCTUA_WHATSAPP_ALLOWLIST=

# === Local-only / development ────────────────────────────────────────────────

# URL the CLI uses to talk to the API; leave as-is for local dev.
NOCTUA_API_URL=http://127.0.0.1:8000
